# ═══════════════════════════════════════════════════════
# ABODE — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ═══════════════════════════════════════════════════════

# ─── Google OAuth (Sign-In) ────────────────────────────
# Used for: Google One-Tap + button sign-in flow
# Setup:
#   1. Go to console.cloud.google.com → your project
#   2. Go to "APIs & Services" → "Credentials"
#   3. Create an OAuth 2.0 Client ID (type: Web application)
#   4. Add authorized JavaScript origins:
#      - http://localhost:3000 (dev)
#      - https://yourdomain.com (prod)
#   5. Add authorized redirect URIs:
#      - http://localhost:3000 (dev)
#      - https://yourdomain.com (prod)
#   6. Copy the Client ID below
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── Google Places API ──────────────────────────────────
# Used for: Address autocomplete + place details
# Setup:
#   1. Go to console.cloud.google.com
#   2. Create a new project (or use existing)
#   3. Enable "Places API" (NOT Places API New — use the classic one)
#   4. Create an API key under "Credentials"
#   5. Restrict the key: Application restrictions → HTTP referrers
#      Add: localhost:3000/* and yourdomain.com/*
#   6. Restrict the key: API restrictions → Select APIs → Places API
#   Estimated cost: $0.017/1000 autocomplete requests, $0.017/1000 details
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ─── Apify ──────────────────────────────────────────────
# Used for: Zillow property data + Airbnb listing scraping
# Setup:
#   1. Go to apify.com → Sign up (free tier available)
#   2. Go to Settings → Integrations → API token
#   3. Copy your personal API token
#   Actors used (pay-per-use, ~$0.05–0.25 per run):
#     - one-api/zillow-scrape-address-url-zpid  (ZPID lookup)
#     - mido_99/zillow-details-scraper          (Property details)
#     - tri_angle/airbnb-rooms-urls-scraper     (Airbnb listings)
APIFY_API_TOKEN=your_apify_api_token_here

